{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sistema-turnos-frontend",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
